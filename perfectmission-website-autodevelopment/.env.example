AUTODEV_MEMORY_HEALTH_OPENCLAW_PLUGIN="hindsight-openclaw"
AUTODEV_MEMORY_HEALTH_SWARM_URL=""
AUTODEV_MEMORY_HEALTH_HTTP_TIMEOUT_SECONDS=5

AUTODEV_MEMORY_INTERVAL_MINUTES=20
AUTODEV_RUN_INTERVAL_MINUTES=30
AUTODEV_HEARTBEAT_MINUTE=17
AUTODEV_DOCTOR_MINUTE=7
